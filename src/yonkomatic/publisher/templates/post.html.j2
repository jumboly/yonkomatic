<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ episode.title }} | yonkomatic</title>
  <link rel="stylesheet" href="../css/style.css">
</head>
<body>
  <main class="post">
    <p class="meta">
      <a href="../index.html">← 一覧</a>
      <span class="date">{{ episode.date }}</span>
      {% if episode.week %}<span class="week">{{ episode.week }}</span>{% endif %}
    </p>
    <h1>第{{ episode.number }}話: {{ episode.title }}</h1>
    <figure>
      <img src="../images/{{ image_filename }}" alt="{{ episode.title }}">
    </figure>
    <p class="summary">{{ episode.summary_no_spoiler }}</p>
  </main>
</body>
</html>
