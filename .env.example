# yonkomatic environment variables
# Copy to .env and fill in real values for local development.
# In GitHub Actions, register these as Repository Secrets instead.

# AI providers (used from Step 2 onward)
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_STUDIO_API_KEY=...

# Publishers — only the ones you have enabled in config.yaml are required
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C...
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Common
LOG_LEVEL=INFO
DRY_RUN=false
